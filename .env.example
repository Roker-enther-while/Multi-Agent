PROJECT_NAME=VietMIRA
ENVIRONMENT=local
API_V1_PREFIX=/api/v1

POSTGRES_USER=vietmira
POSTGRES_PASSWORD=vietmira
POSTGRES_DB=vietmira
DATABASE_URL=postgresql+psycopg://vietmira:vietmira@postgres:5432/vietmira

QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379/0
IMAGE_EMBEDDING_DIM=64
TEXT_EMBEDDING_DIM=64
IMAGE_COLLECTION_NAME=image_frames_clip
TEXT_COLLECTION_NAME=text_chunks_dense
AUDIO_COLLECTION_NAME=audio_text_dense
ENABLE_QDRANT_INDEXING=true

MEDIA_ROOT=/data/media
STORAGE_ROOT=/data/raw
PROCESSED_ROOT=/data/processed
PUBLIC_MEDIA_URL=/media
VIDEO_KEYFRAME_INTERVAL_SECONDS=5
VIDEO_MAX_KEYFRAMES=20
TEXT_CHUNK_SIZE=800
TEXT_CHUNK_OVERLAP=100
MAX_TEXT_INGEST_CHARS=200000

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=vietmira-media

BACKEND_CORS_ORIGINS=http://localhost:3000
HEALTH_FAIL_ON_DEPENDENCY_ERROR=true

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
